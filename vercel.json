{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "includeFiles": "**/*"
    }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api/index" },
    { "source": "/api/", "destination": "/api/index" },
    { "source": "/((?!api/|v/|favicon\\.).*)", "destination": "/index.html" }
  ]
}
