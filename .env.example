# PostgreSQL connection string
# For Vercel: use DATABASE_URL or POSTGRES_URL from Vercel dashboard
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mydevsite

# Frontend API base URL (for React/Vite)
# In production: https://iristonweb.ru
# In development: http://localhost:5000 (or leave empty to use current origin)
VITE_API_BASE=https://iristonweb.ru

# Admin panel credentials (for legacy Express server, not used in serverless)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me

# Session secret (for legacy Express server, not used in serverless)
SESSION_SECRET=change-me-too

# Optional: Telegram notifications (new lead/contact -> Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Port (default 5000, for local Express server only)
PORT=5000
