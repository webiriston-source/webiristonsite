# PostgreSQL connection string
# For Vercel: use DATABASE_URL or POSTGRES_URL from Vercel dashboard
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mydevsite

# Frontend API base URL (for React/Vite)
# In production: use the same host your API uses (with or without www — consistently)
# Example: https://iristonweb.ru or https://www.iristonweb.ru
VITE_API_BASE=https://iristonweb.ru
# Telegram bot username used by frontend links/deep-links (without @).
# Must belong to the SAME bot as TELEGRAM_BOT_TOKEN.
VITE_TELEGRAM_BOT_USERNAME=iristonweb

# Admin panel — REQUIRED on Vercel serverless for reliable login (checked before DB)
# Must match Production env in Vercel dashboard (values are trimmed; surrounding "quotes" are stripped)
# After adding vars: Vercel → Deployments → Redeploy production (env applies only to new deploys).
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me

# Optional: create DB user with `npm run create-admin` — login also works via users table + bcryptjs hash

# Session secret (for legacy Express server only)
SESSION_SECRET=change-me-too

# Telegram: site lead notifications (admin chat) + bot webhook features
# Apply DB schema so table telegram_subscribers exists (e.g. drizzle-kit push / run migrations) — bot menu/calc need it.
# Webhook URL must match your API host (same as VITE_API_BASE / production domain), e.g.:
#   https://iristonweb.ru/api/?action=telegramWebhook
# Set setWebhook for the SAME bot as TELEGRAM_BOT_TOKEN (BotFather → token → API); site links must use that bot @username.
# /start greets users if DB is down, but flows need the table.
# Optional explicit webhook URL (if empty, backend builds it from VITE_API_BASE):
# TELEGRAM_WEBHOOK_URL=https://iristonweb.ru/api/?action=telegramWebhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_ID=
# Public HTTPS URL for referral welcome image in the bot (optional; if empty, bot sends text only)
TELEGRAM_REFERRAL_IMAGE_URL=

# Optional: Port (default 5000, for local Express server only)
PORT=5000
