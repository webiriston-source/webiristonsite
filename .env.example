# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mydevsite

# Admin panel credentials
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me

# Session secret (change in production)
SESSION_SECRET=change-me-too

# Optional: Telegram notifications (new lead/contact -> Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Port (default 5000)
PORT=5000

# Optional: local fallback storage (useful if PostgreSQL is not available)
# STORAGE_MODE=file
